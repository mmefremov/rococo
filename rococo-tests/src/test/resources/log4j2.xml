<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="STDOUT" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>

  <Loggers>
    <Logger name="org.hibernate" level="ERROR" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="com.codeborne.selenide.webdriver.WebDriverFactory" level="ERROR" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="com.codeborne.selenide.impl.WebDriverThreadLocalContainer" level="ERROR" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="com.codeborne.selenide.drivercommands.CreateDriverCommand" level="ERROR" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="com.codeborne.selenide.drivercommands.CloseDriverCommand" level="ERROR" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="com.codeborne.selenide.drivercommands.DisposablesRegistry" level="ERROR" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="io.qameta.allure.AllureLifecycle" level="OFF" additivity="false"/>

    <Root level="INFO">
      <AppenderRef ref="STDOUT"/>
    </Root>
  </Loggers>
</Configuration>
